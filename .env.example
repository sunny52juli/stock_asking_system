# ==================== API配置 ====================
# LLM API (src.agent / stock_asking_system 等共用)
DEFAULT_API_KEY=your-api-key-here
DEFAULT_MODEL=deepseek-chat
DEFAULT_API_URL=https://api.deepseek.com/v1

# ==================== 数据模块配置 (docs/data) ====================
# Tushare Pro Token (DataService / DataGenerator 共用)
DATA_SOURCE_TOKEN=your_tushare_token_here

# ==================== 输出配置 ====================
# 策略脚本保存目录（交互式筛选系统）
# 默认值: ./app/screening_scripts (相对于项目根目录)
# 建议设置为绝对路径，避免路径混淆
SCREENER_SCRIPTS_DIR=D:\code\QuantitativeSystem\stock_asking_system\app\screening_scripts

# ==================== 使用说明 ====================
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 将 your-deepseek-api-key-here 替换为你的实际API密钥
# 3. 将 your_tushare_token_here 替换为 Tushare Pro Token (数据模块必填)
# 4. 根据需要设置 DATA_CACHE_ROOT 或使用默认路径
# 5. 设置 SCREENER_SCRIPTS_DIR 为策略脚本保存路径（建议使用绝对路径）
# 6. .env 文件不会被提交到版本控制 (已在 .gitignore 中配置)
